
# ─── CalmNote Backend Environment Variables ───────────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.
#
# ─── PostgreSQL Connection ─────────────────────────────────────────────────────
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
#
# Default: connects to a local PostgreSQL server with user=postgres, password=password
# Change the password below to match your PostgreSQL installation.
#
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/calmnote
#
# Other examples:
#   Local (no password):  postgresql+psycopg2://postgres:postgres@localhost:5432/calmnote
#   Supabase:             postgresql+psycopg2://postgres:<password>@db.<project>.supabase.co:5432/postgres
#   Railway:              postgresql+psycopg2://postgres:<password>@<host>.railway.app:5432/railway
#   Docker Compose:       postgresql+psycopg2://postgres:postgres@db:5432/calmnote
#
# ─── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
# Set to "production" when deploying to disable auto-reload

# ─── Server Settings (optional) ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
